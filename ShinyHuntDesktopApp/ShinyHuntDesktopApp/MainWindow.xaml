<Window x:Class="ShinyHuntDesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Pokemon Shiny Hunting App" Height="600" Width="800">
    <Grid Background="#10131c">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161b27" CornerRadius="10" Margin="10" Padding="5" VerticalAlignment="Center">
            <Label Content="SHINY TRACKER" Foreground="White" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Border>
        <!-- Contains Webcam Feed and Statistics -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <!-- Left: Webcam Feed -->
            <Border Grid.Column="0" Background="#161b27" CornerRadius="10" Margin="10,10,5,10" BorderThickness="1,1,1,1" BorderBrush="#222840">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="LIVE FEED" Padding="10" Foreground="#7a82a0" BorderBrush="#222840" BorderThickness="0,0,0,1"></Label>
                    <Image Grid.Row="1" Name="WebcamImage" Source="{Binding CurrentFrame}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <!-- Right: Statistics / Previous Images -->
            <Border Grid.Column="1" Background="#161b27" CornerRadius="10" Margin="5,10,10,10" BorderThickness="1,1,1,1" BorderBrush="#222840">
                <!-- Put stats controls here -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="CURRENT HUNT" Padding="10" Foreground="#7a82a0" BorderThickness="0,0,0,1" BorderBrush="#222840" />

                    <!-- Encounters -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="TARGET POKEMON" Foreground="#7a82a0" Padding="10"/>
                        <ComboBox Grid.Row="1" Template="{StaticResource ComboBoxStyle1}" ItemsSource="{Binding PokemonNames}" Foreground="#7a82a0" Padding="10" Margin="10,0,10,0" Background="#161b27" BorderBrush="#222840" BorderThickness="1"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
