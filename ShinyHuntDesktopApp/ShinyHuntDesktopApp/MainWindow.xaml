<Window x:Class="ShinyHuntDesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShinyHuntDesktopApp"
        mc:Ignorable="d"
        Title="Pokemon Shiny Hunting App" Height="450" Width="800">
    <Grid Background="#212121">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="#414141"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="Background" Value="#414141"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style TargetType="RowDefinition">

            </Style>
        </Grid.Resources>

        <Border Background="#414141" CornerRadius="15" Margin="5"
            HorizontalAlignment="Stretch" VerticalAlignment="Center">
            <Label Content="Pokemon Shiny Hunting App" Foreground="White" Margin="5"
                   HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
        </Border>
        <!-- Contains Webcam Feed and Statistics -->
        <Grid Grid.Row="1" Background="#212121">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <!-- Left: Webcam Feed -->
            <Border Grid.Column="0" Background="#414141" CornerRadius="10" Margin="5">
                <StackPanel Margin="5">
                    <Label Content="LIVE FEED"></Label>
                    <Image Name="WebcamImage" Stretch="Uniform"/>
                </StackPanel>
            </Border>
            <!-- Right: Statistics / Previous Images -->
            <Border Grid.Column="1" Background="#414141" CornerRadius="10" Margin="5">
                <!-- Put stats controls here -->
                <StackPanel Margin="5">
                    <Label Content="Stats" Foreground="White" HorizontalAlignment="Left"/>
                    <!-- Example: add previous images, counters, etc. -->
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
